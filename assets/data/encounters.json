                },
                {
                    "text": "Stare deeply (Requires: SPI > 15).",
                    "requirement": {
                        "stat": "SPIRITUAL_STRENGTH",
                        "value": 15
                    },
                    "successEffect": {
                        "type": "GIVE_XP",
                        "amount": 500,
                        "text": "You understand the nature of the void."
                    }
