                    "requirement": {
                        "stat": "PERCEPTION",
                        "value": 10
                    },
                    "successEffect": {
                        "type": "GIVE_ITEM",
                        "itemId": "RUBY_EYE",
                        "text": "You notice the eye is a loose gem. You pry it out."
                    }
                },
                {
                    "text": "Leave it alone.",
                    "type": "LEAVE"
                }
            ]
        },
        {
            "id": "EVENT_BROKEN_MIRROR",
